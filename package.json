{
  "name": "softeni-pick",
  "version": "0.1.0",
  "private": true,
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:import/errors",
    "plugin:import/warnings",
    "plugin:prettier/recommended",
    "next/core-web-vitals"
  ],
  "plugins": [
    "import",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "import/order": [
      "error",
      {
        "groups": [
          "builtin",
          "external",
          "internal",
          [
            "parent",
            "sibling",
            "index"
          ]
        ],
        "newlines-between": "always",
        "alphabetize": {
          "order": "asc",
          "caseInsensitive": true
        }
      }
    ],
    "prettier/prettier": "error"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-players-json.mjs && node scripts/generate-players-lite.mjs && npm run playerstats:facts && node scripts/generate-player-analysis.mjs && node scripts/generate-beta-matches-json.mjs && node scripts/generate-match-reverse-index.mjs && npm run playerstats:rankings",
    "build": "NEXT_PUBLIC_GA_ID=$NEXT_PUBLIC_GA_ID next build",
    "check:growth": "node scripts/check-growth-analysis.mjs",
    "crawl:local-tournaments": "node scripts/crawl-local-tournaments.mjs",
    "playerstats:facts": "ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/generate-facts.ts",
    "playerstats:rankings": "ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/generate-rankings.ts",
    "ratings:generate": "node scripts/ranking/generate-ratings.mjs",
    "ranking:backtest": "node scripts/ranking/backtest.mjs",
    "playerstats:public": "ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/generate-public-json.ts",
    "playerstats:test": "ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/run-tests.ts",
    "playerstats:verify": "ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/verify-facts-golden.ts && ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/verify-facade.ts && ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/verify-analysis-migration.ts && ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/verify-golden-final.ts",
    "playerstats:perf": "ts-node --project scripts/playerStats/tsconfig.json scripts/playerStats/verify-performance.ts",
    "start": "next start",
    "postbuild": "next-sitemap && node scripts/sort-sitemaps.mjs && node scripts/filter-noindex-from-sitemap.mjs",
    "lint": "eslint --fix ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.78.0",
    "cheerio": "^1.2.0",
    "iconv-lite": "^0.7.2",
    "next": "^15.5.7",
    "next-sitemap": "^4.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.17.46",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.26.0",
    "eslint-config-next": "15.3.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
